{
  "manifest_version": 3,
  "name": "Quicker Ticker",
  "version": "2.0.0",
  "description": "Fast stock + ETF watchlist with grouping, sparklines, charts, and news. Works out of the box, no API keys required.",
  "action": {
    "default_title": "Quicker Ticker",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "alarms",
    "offscreen",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.finance.yahoo.com/*",
    "https://feeds.finance.yahoo.com/*",
    "https://stooq.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
